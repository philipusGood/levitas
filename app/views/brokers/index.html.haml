- if Broker.count.zero?
  .flex.flex-col.justify-center.items-center.h-screen
    %h3.mt-2.text-sm.font-semibold.text-gray-900
      = t('.no_brokers')
    %p.mt-1.text-sm.text-gray-500
      = t('.start_adding_brokers')
    .mt-6
      = link_to new_broker_path, class: "inline-block px-4 py-2 text-base rounded-lg flex justify-center border border-[#E4E4E7] hover:cursor-pointer bg-blue-600 text-white" do
        = t('.invite_brokers')
- else
.flex.flex-col.gap-y-12
  .flex.items-center
    %h1.font-serif.font-bold.leading-9.text-gray-900.text-2xl
      = t('.brokers')
  .flex.flex-col.gap-8
    .flex.flex-col.md:flex-row.items-center.justify-between.gap-4
      = form_with(url:brokers_path, class: "w-full md:w-auto", method: :get) do
        %div
          .relative.rounded-md.shadow-sm.md:max-w-sm
            = text_field_tag :query, params[:query], class: "levitas-form-input w-full", placeholder: "Search"
            .pointer-events-none.absolute.inset-y-0.right-0.flex.items-center.pr-3
              %svg{:fill => "none", :height => "20", :viewbox => "0 0 20 20", :width => "20", :xmlns => "http://www.w3.org/2000/svg"}
                %path{"clip-rule" => "evenodd", :d => "M8 4.00077C6.93913 4.00077 5.92172 4.42219 5.17157 5.17234C4.42143 5.92248 4 6.9399 4 8.00077C4 9.06163 4.42143 10.079 5.17157 10.8292C5.92172 11.5793 6.93913 12.0008 8 12.0008C9.06087 12.0008 10.0783 11.5793 10.8284 10.8292C11.5786 10.079 12 9.06163 12 8.00077C12 6.9399 11.5786 5.92248 10.8284 5.17234C10.0783 4.42219 9.06087 4.00077 8 4.00077ZM2 8.00077C1.99988 7.05647 2.22264 6.12548 2.65017 5.28351C3.0777 4.44154 3.69792 3.71236 4.4604 3.15529C5.22287 2.59822 6.10606 2.22898 7.03815 2.0776C7.97023 1.92622 8.92488 1.99698 9.82446 2.28412C10.724 2.57126 11.5432 3.06667 12.2152 3.73006C12.8872 4.39346 13.3931 5.2061 13.6919 6.1019C13.9906 6.9977 14.0737 7.95136 13.9343 8.88532C13.795 9.81928 13.4372 10.7072 12.89 11.4768L17.707 16.2938C17.8892 16.4824 17.99 16.735 17.9877 16.9972C17.9854 17.2594 17.8802 17.5102 17.6948 17.6956C17.5094 17.881 17.2586 17.9862 16.9964 17.9884C16.7342 17.9907 16.4816 17.8899 16.293 17.7078L11.477 12.8918C10.5794 13.53 9.52335 13.9089 8.42468 13.9869C7.326 14.0648 6.22707 13.8389 5.2483 13.3337C4.26953 12.8286 3.44869 12.0638 2.87572 11.1231C2.30276 10.1824 1.99979 9.1022 2 8.00077Z", :fill => "#3F3F46", "fill-rule" => "evenodd"}
      = link_to new_broker_path, class: "max-md:w-full" do
        =levitas_button(:button, t('.invite_brokers'), "primary", nil, :wide)
    .flex.overflow-x-auto
      %table.rounded-table.w-full.select-text
        %thead
          %tr
            %th{:scope => "col"}
              = t('.full_name')
            %th{:scope => "col"}
              = t('.email')
            %th{:scope => "col"}
              = t('.status')
            - if current_user.admin?
              %th{:scope => "col"}
                %span.sr-only
                  = t('.impersonate')
            %th.relative{:scope => "col"}
              %span.sr-only
                = t('.edit')
            %th.relative{:scope => "col"}
              %span.sr-only
                = t('.delete')
        %tbody
          - @brokers.each do |broker|
            %tr
              %td{"data-label": t('.full_name')}
                = link_to broker.full_name, broker_path(broker)
              %td{"data-label": t('.email')}
                = broker.email
              %td{"data-label": t('.status')}
                = status(broker)
              - if current_user.admin?
                %td
                  = button_to impersonations_path(user_id: broker.id), class: "text-blue-500 hover:text-blue-400", data: { turbo: false } do
                    = t('.impersonate')
              %td{"data-label": ""}
                - if broker.pending_account_setup? && broker.invited?
                  = link_to send_invite_broker_path(broker), class: "text-blue-500 hover:text-blue-400", data: { turbo_method: :post } do
                    Resend Invite
                - else
                  = link_to edit_broker_path(broker), class: "text-blue-500 hover:text-blue-400" do
                    = t('.edit')
              %td{"data-label": ""}
                = link_to broker_path(broker), class: "text-red-600 hover:text-red-400", data: { turbo_confirm: "Are you sure you want to delete this?", turbo_method: :delete, turbo_frame: :top } do
                  = t('.delete')

    = render 'partials/pagination', collection: @brokers

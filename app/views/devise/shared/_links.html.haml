.text-xs.text-gray-600.mt-4
  - if controller_name != 'sessions'
    .mb-2
      = link_to "Log in", new_session_path(resource_name), class: "text-blue-500 text-sm"
  - if devise_mapping.confirmable? && controller_name != 'confirmations'
    .mb-2
      = link_to "Didn't receive confirmation instructions?", new_confirmation_path(resource_name), class: "text-blue-500 text-sm"
  - if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks'
    .mb-2
      = link_to "Didn't receive unlock instructions?", new_unlock_path(resource_name), class: "text-blue-500 text-sm"
  - if devise_mapping.omniauthable?
    - resource_class.omniauth_providers.each do |provider|
      = button_to "Sign in with #{OmniAuth::Utils.camelize(provider)}", omniauth_authorize_path(resource_name, provider), data: { turbo: false }, class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded mt-2"

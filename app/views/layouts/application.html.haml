  %body.lg:bg-gray-50{ data: { controller: "popover sidebar", action: "click->popover#hide" } }
    = render 'layouts/confirm_email'
    = render 'partials/pending_invitations'
    = render 'partials/impersonation_banner'
    - if notice
      = content_for :banners do
        .bg-green-100.w-full.text-green-700.flex.items-center{class: "min-h-[64px]"}
          %span.inline-block.align-middle.text-center.w-full
            = notice

    %div.lg:flex.lg:overflow-hidden.lg:h-screen{"data-controller": "layout modal", "data-layout-target": "mainContainer"}
      = render "layouts/navigation"
      = turbo_frame_tag :modal
      %main.flex-auto.lg:overflow-y-auto{"data-layout-target": "content", "data-controller": "profile-navigation", "data-action": "touchmove->profile-navigation#highlightPosition:passive scroll->profile-navigation#highlightPosition"}
        = yield(:banners)
        .p-6.lg:px-10
          = yield
      %aside.fixed.right-0.top-0.h-full.translate-x-full.transition-all.bg-white.drop-shadow-xl.overflow-y-auto.z-50{"data-sidebar-target": "sidebar", class: "min-w-[300px] max-w-[400px]"}
        = turbo_frame_tag :sidebar_content
      .invisible.absolute.left-0.top-0.h-full.w-full.transition-all.bg-black.opacity-0.overflow-hidden.z-40{"data-sidebar-target": "backdrop", "data-action": "click->sidebar#toggle"}

= turbo_frame_tag dom_id(@document, :document) do
  = form_with(model: @document, url: deal_document_path(@deal, @document)) do |f|
    .flex.flex-wrap.items-center.gap-3.p-3.w-full.bg-gray-100.rounded-lg{id: "document_#{@document.id}"}
      .flex.items-center.justify-center.gap-1.w-10.h-10.bg-blue-600.rounded-full{class: "min-w-[2.5rem]"}
        = image_tag("icons/document.svg")
      .flex.flex-col.flex-1.truncate
        %p.font-bold.flex.items-center.gap-2
          %input{type: "text", name: "filename", value: @document.blob.metadata[:filename] || @document.blob.filename.to_s, class: "bg-transparent border-none text-gray-700 focus:ring-0 focus:outline-none p-0 m-0", autofocus: true }

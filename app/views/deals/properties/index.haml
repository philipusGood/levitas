%div
  %h1.deal-creator-step-title
    = t('.title')
  %p.deal-creator-step-description
    = t('.leading')
  = render 'devise/shared/error_messages', resource: @property

  = form_for @property, url: deal_property_index_path(@deal), method: :post, data: { turbo: false } do |f|
    %section.mb-8
      %h2.deal-creator-section-title Property Information
      .py-6
        .flex.flex-col.sm:flex-row.gap-6.mb-6
          .flex-1
            = f.label :type, t('.type'), class: "deal-creator-label" do
              = t('.type')
              = ai_badge(f.object.type, 'property.type')
            = f.select :type, options_for_select(SelectOptions::PROPERTY_TYPE, f.object.type), {}, {class: 'deal-creator-select'} 
          .flex-1
            = f.label :mls_number, class: "deal-creator-label" do
              = t('.mls')
              %span.font-thin.text-xs
                = t('.optional')
              = ai_badge(f.object.mls_number, 'property.mls_number')
            = f.number_field :mls_number, class: "deal-creator-input-text "
        .flex.flex-col.sm:flex-row.gap-6
          .flex-1
            = f.label :price, t('.property_price'), class: "deal-creator-label" do
              = t('.property_price')
              = ai_badge(f.object.price, 'property.price')
            = f.text_field :price, class: "deal-creator-input-text "
          .flex-1
            .flex.gap-4.sm:justify-between.items-center
              = f.label :approximate_closing_date, t('.approximate_closing_deal'), class: "deal-creator-label" do
                = t('.approximate_closing_deal')
                = ai_badge(f.object.approximate_closing_date, 'property.approximate_closing_date')
              .tooltip.mb-2
                %span
                  %svg{:fill => "none", :height => "16", :viewbox => "0 0 16 16", :width => "16", :xmlns => "http://www.w3.org/2000/svg"}
                    %path{"clip-rule" => "evenodd", :d => "M14.3996 7.99961C14.3996 9.69699 13.7253 11.3249 12.5251 12.5251C11.3249 13.7253 9.69699 14.3996 7.99961 14.3996C6.30222 14.3996 4.67436 13.7253 3.47413 12.5251C2.27389 11.3249 1.59961 9.69699 1.59961 7.99961C1.59961 6.30222 2.27389 4.67436 3.47413 3.47413C4.67436 2.27389 6.30222 1.59961 7.99961 1.59961C9.69699 1.59961 11.3249 2.27389 12.5251 3.47413C13.7253 4.67436 14.3996 6.30222 14.3996 7.99961ZM7.99961 5.59961C7.85905 5.59947 7.72093 5.63637 7.59917 5.70659C7.4774 5.77682 7.37629 5.87788 7.30601 5.99961C7.25526 6.09391 7.1861 6.17706 7.10262 6.24414C7.01914 6.31121 6.92304 6.36084 6.82002 6.39009C6.71701 6.41934 6.60916 6.4276 6.50289 6.4144C6.39662 6.40119 6.29408 6.36679 6.20136 6.31322C6.10863 6.25965 6.0276 6.18801 5.96307 6.10254C5.89855 6.01708 5.85184 5.91953 5.82571 5.81568C5.79959 5.71182 5.79458 5.60378 5.81098 5.49796C5.82738 5.39213 5.86487 5.29068 5.92121 5.19961C6.18538 4.7421 6.59314 4.38454 7.08123 4.18238C7.56932 3.98022 8.11048 3.94476 8.62078 4.0815C9.13108 4.21823 9.58201 4.51952 9.90363 4.93865C10.2252 5.35777 10.3996 5.87131 10.3996 6.39961C10.3998 6.8961 10.246 7.38043 9.95942 7.78589C9.67287 8.19135 9.26767 8.498 8.79961 8.66361V8.79961C8.79961 9.01178 8.71532 9.21527 8.56529 9.36529C8.41527 9.51532 8.21178 9.59961 7.99961 9.59961C7.78744 9.59961 7.58395 9.51532 7.43392 9.36529C7.28389 9.21527 7.19961 9.01178 7.19961 8.79961V7.99961C7.19961 7.78744 7.28389 7.58395 7.43392 7.43392C7.58395 7.28389 7.78744 7.19961 7.99961 7.19961C8.21178 7.19961 8.41527 7.11532 8.56529 6.96529C8.71532 6.81527 8.79961 6.61178 8.79961 6.39961C8.79961 6.18744 8.71532 5.98395 8.56529 5.83392C8.41527 5.68389 8.21178 5.59961 7.99961 5.59961ZM7.99961 11.9996C8.21178 11.9996 8.41527 11.9153 8.56529 11.7653C8.71532 11.6153 8.79961 11.4118 8.79961 11.1996C8.79961 10.9874 8.71532 10.784 8.56529 10.6339C8.41527 10.4839 8.21178 10.3996 7.99961 10.3996C7.78744 10.3996 7.58395 10.4839 7.43392 10.6339C7.28389 10.784 7.19961 10.9874 7.19961 11.1996C7.19961 11.4118 7.28389 11.6153 7.43392 11.7653C7.58395 11.9153 7.78744 11.9996 7.99961 11.9996Z", :fill => "#3F3F46", "fill-rule" => "evenodd"}
                .tooltip-content
                  %p.text-sm.text-white.font-medium{:class => "mb-[6px]"} Tip
                  %p.text-xs.text-gray-400 It's okay if you don't know the exact closing date, but you can add an estimated date.
            = f.text_field :approximate_closing_date, class: "deal-creator-input-text datepicker"

    %section.mb-8
      .bg-gray-100.border-radius.h-100.rounded-md.p-4{data: { controller: "properties"}}
        %section.mb-8
          %h2.deal-creator-section-title
            = t('.has_mortgages')
            = ai_badge_collection(@property.mortgages.map(&:serialize), 'property.mortgages')
          %div.flex.flex-row.justify-center.items-center
            %div.flex-1
              %p.text-sm
                =t('.mortgages_description')
            %div.justify-self-end
        %section{data: { controller: "form"} }
          %div
            %template{"data-form-target" => "template"}
              = f.fields_for "mortgages[]", Deal::Property::Mortgage.new({ institution: "", monthly_payment: 0, amount_due: 0}) do |mortage_fields|
                .item
                  .flex.flex-col.sm:flex-row.gap-6.mb-6
                    %div.flex-col.self-end
                      %div{class: "w-[40px] h-[40px] bg-gray-200 rounded-full algin-center items-center flex justify-center"}
                        %span.text-sm
                          = "INDEX_TEMPLATE"
                    .flex-1
                      = mortage_fields.label :institution, t('.institution'), class: "deal-creator-label"
                      = mortage_fields.text_field :institution, class: "deal-creator-input-text"
                    .flex-1
                      = mortage_fields.label :monthly_payment, t('.monthly_payment'), class: "deal-creator-label"
                      = mortage_fields.number_field :monthly_payment, class: "deal-creator-input-text"
                    .flex-1
                      = mortage_fields.label :amount_due, t('.amount_due'), class: "deal-creator-label"
                      = mortage_fields.number_field :amount_due, class: "deal-creator-input-text"
                    .flex-1
                      = mortage_fields.label :end_date, t('.end_date'), class: "deal-creator-label"
                      = mortage_fields.text_field :end_date, class: "deal-creator-input-text datepicker", placeholder: "YYYY-MM-DD"
                    %div.flex.justify-center.self-end.pb-2
                      %button{type: "button", "data-action" => "click->form#remove"}
                        %svg{:fill => "none", :height => "24", :viewbox => "0 0 20 20", :width => "24", :xmlns => "http://www.w3.org/2000/svg"}
                          %path{"clip-rule" => "evenodd", :d => "M9 2C8.81434 2.0001 8.63237 2.05188 8.47447 2.14955C8.31658 2.24722 8.18899 2.38692 8.106 2.553L7.382 4H4C3.73478 4 3.48043 4.10536 3.29289 4.29289C3.10536 4.48043 3 4.73478 3 5C3 5.26522 3.10536 5.51957 3.29289 5.70711C3.48043 5.89464 3.73478 6 4 6V16C4 16.5304 4.21071 17.0391 4.58579 17.4142C4.96086 17.7893 5.46957 18 6 18H14C14.5304 18 15.0391 17.7893 15.4142 17.4142C15.7893 17.0391 16 16.5304 16 16V6C16.2652 6 16.5196 5.89464 16.7071 5.70711C16.8946 5.51957 17 5.26522 17 5C17 4.73478 16.8946 4.48043 16.7071 4.29289C16.5196 4.10536 16.2652 4 16 4H12.618L11.894 2.553C11.811 2.38692 11.6834 2.24722 11.5255 2.14955C11.3676 2.05188 11.1857 2.0001 11 2H9ZM7 8C7 7.73478 7.10536 7.48043 7.29289 7.29289C7.48043 7.10536 7.73478 7 8 7C8.26522 7 8.51957 7.10536 8.70711 7.29289C8.89464 7.48043 9 7.73478 9 8V14C9 14.2652 8.89464 14.5196 8.70711 14.7071C8.51957 14.8946 8.26522 15 8 15C7.73478 15 7.48043 14.8946 7.29289 14.7071C7.10536 14.5196 7 14.2652 7 14V8ZM12 7C11.7348 7 11.4804 7.10536 11.2929 7.29289C11.1054 7.48043 11 7.73478 11 8V14C11 14.2652 11.1054 14.5196 11.2929 14.7071C11.4804 14.8946 11.7348 15 12 15C12.2652 15 12.5196 14.8946 12.7071 14.7071C12.8946 14.5196 13 14.2652 13 14V8C13 7.73478 12.8946 7.48043 12.7071 7.29289C12.5196 7.10536 12.2652 7 12 7Z", :fill => "#DC2626", "fill-rule" => "evenodd"}
                    %div.flex.justify-center.self-end.pb-2
                      %button.handle{type: "button", class: "hover:cursor-move"}
                        %svg{fill: "none", height: "24", viewbox: "0 0 24 24", width: "24", xmlns: "http://www.w3.org/2000/svg"}
                          %path{"clip-rule" => "evenodd", d: "M5 9C5 8.73478 5.10536 8.48043 5.29289 8.29289C5.48043 8.10536 5.73478 8 6 8H18C18.2652 8 18.5196 8.10536 18.7071 8.29289C18.8946 8.48043 19 8.73478 19 9C19 9.26522 18.8946 9.51957 18.7071 9.70711C18.5196 9.89464 18.2652 10 18 10H6C5.73478 10 5.48043 9.89464 5.29289 9.70711C5.10536 9.51957 5 9.26522 5 9ZM5 15C5 14.7348 5.10536 14.4804 5.29289 14.2929C5.48043 14.1054 5.73478 14 6 14H18C18.2652 14 18.5196 14.1054 18.7071 14.2929C18.8946 14.4804 19 14.7348 19 15C19 15.2652 18.8946 15.5196 18.7071 15.7071C18.5196 15.8946 18.2652 16 18 16H6C5.73478 16 5.48043 15.8946 5.29289 15.7071C5.10536 15.5196 5 15.2652 5 15Z", fill: "#A1A1AA", "fill-rule" => "evenodd"}

            %div{data: { "controller" => "sortable", "sortable-handle-value" => ".handle", "form-target" => "items", "properties-target" => "mortages"}}
              - @property.mortgages&.each_with_index do |mortage, index|
                = render 'devise/shared/error_messages', resource: mortage 
                = f.fields_for "mortgages[]", mortage do |mortage_fields|
                  .item
                    .flex.flex-col.sm:flex-row.gap-6.mb-6
                      %div.flex-col.self-end
                        %div{class: "w-[40px] h-[40px] bg-gray-200 rounded-full algin-center items-center flex justify-center"}
                          %span.text-sm
                      .flex-1
                        = mortage_fields.label :institution, t('.institution'), class: "deal-creator-label"
                        = mortage_fields.text_field :institution, class: "deal-creator-input-text"
                      .flex-1
                        = mortage_fields.label :monthly_payment, t('.monthly_payment'), class: "deal-creator-label"
                        = mortage_fields.number_field :monthly_payment, class: "deal-creator-input-text"
                      .flex-1
                        = mortage_fields.label :amount_due, t('.amount_due'), class: "deal-creator-label"
                        = mortage_fields.number_field :amount_due, class: "deal-creator-input-text"
                      .flex-1
                        = mortage_fields.label :end_date, t('.end_date'), class: "deal-creator-label"
                        = mortage_fields.text_field :end_date, class: "deal-creator-input-text datepicker", placeholder: "YYYY-MM-DD"
                      %div.flex.justify-center.self-end.pb-2
                        %button{type: "button", "data-action" => "click->form#remove" }
                          %svg{:fill => "none", :height => "24", :viewbox => "0 0 20 20", :width => "24", :xmlns => "http://www.w3.org/2000/svg"}
                            %path{"clip-rule" => "evenodd", :d => "M9 2C8.81434 2.0001 8.63237 2.05188 8.47447 2.14955C8.31658 2.24722 8.18899 2.38692 8.106 2.553L7.382 4H4C3.73478 4 3.48043 4.10536 3.29289 4.29289C3.10536 4.48043 3 4.73478 3 5C3 5.26522 3.10536 5.51957 3.29289 5.70711C3.48043 5.89464 3.73478 6 4 6V16C4 16.5304 4.21071 17.0391 4.58579 17.4142C4.96086 17.7893 5.46957 18 6 18H14C14.5304 18 15.0391 17.7893 15.4142 17.4142C15.7893 17.0391 16 16.5304 16 16V6C16.2652 6 16.5196 5.89464 16.7071 5.70711C16.8946 5.51957 17 5.26522 17 5C17 4.73478 16.8946 4.48043 16.7071 4.29289C16.5196 4.10536 16.2652 4 16 4H12.618L11.894 2.553C11.811 2.38692 11.6834 2.24722 11.5255 2.14955C11.3676 2.05188 11.1857 2.0001 11 2H9ZM7 8C7 7.73478 7.10536 7.48043 7.29289 7.29289C7.48043 7.10536 7.73478 7 8 7C8.26522 7 8.51957 7.10536 8.70711 7.29289C8.89464 7.48043 9 7.73478 9 8V14C9 14.2652 8.89464 14.5196 8.70711 14.7071C8.51957 14.8946 8.26522 15 8 15C7.73478 15 7.48043 14.8946 7.29289 14.7071C7.10536 14.5196 7 14.2652 7 14V8ZM12 7C11.7348 7 11.4804 7.10536 11.2929 7.29289C11.1054 7.48043 11 7.73478 11 8V14C11 14.2652 11.1054 14.5196 11.2929 14.7071C11.4804 14.8946 11.7348 15 12 15C12.2652 15 12.5196 14.8946 12.7071 14.7071C12.8946 14.5196 13 14.2652 13 14V8C13 7.73478 12.8946 7.48043 12.7071 7.29289C12.5196 7.10536 12.2652 7 12 7Z", :fill => "#DC2626", "fill-rule" => "evenodd"}
                      %div.flex.justify-center.self-end.pb-2
                        %button.handle{type: "button", class: "hover:cursor-move"}
                          %svg{fill: "none", height: "24", viewbox: "0 0 24 24", width: "24", xmlns: "http://www.w3.org/2000/svg"}
                            %path{"clip-rule" => "evenodd", d: "M5 9C5 8.73478 5.10536 8.48043 5.29289 8.29289C5.48043 8.10536 5.73478 8 6 8H18C18.2652 8 18.5196 8.10536 18.7071 8.29289C18.8946 8.48043 19 8.73478 19 9C19 9.26522 18.8946 9.51957 18.7071 9.70711C18.5196 9.89464 18.2652 10 18 10H6C5.73478 10 5.48043 9.89464 5.29289 9.70711C5.10536 9.51957 5 9.26522 5 9ZM5 15C5 14.7348 5.10536 14.4804 5.29289 14.2929C5.48043 14.1054 5.73478 14 6 14H18C18.2652 14 18.5196 14.1054 18.7071 14.2929C18.8946 14.4804 19 14.7348 19 15C19 15.2652 18.8946 15.5196 18.7071 15.7071C18.5196 15.8946 18.2652 16 18 16H6C5.73478 16 5.48043 15.8946 5.29289 15.7071C5.10536 15.5196 5 15.2652 5 15Z", fill: "#A1A1AA", "fill-rule" => "evenodd"}

            .flex.mb-4
              %button.py-2.px-3.border.rounded-lg.border-gray-200.text-gray-600.bg-white{type: "button", "data-action" => "click->form#add", id: "add-liability"}
                = t('.add_mortgages')

    %section.mb-8
      %h2.deal-creator-section-title
        = t('.property_address')
      .py-6
        = f.fields_for :address, @property.address do |address_fields|
          .flex.gap-6.mb-6
            .flex-1
              = address_fields.label :street, t('.street'), class: "deal-creator-label" do
                = t('.street')
                = ai_badge(address_fields.object.street, 'property.address.street')

              = address_fields.text_field :street, class: "deal-creator-input-text "
            .flex-1{:class => "max-w-[174px]"}
              = address_fields.label :unit, t('.unit'), class: "deal-creator-label" do
                = t('.unit')
                %span.font-thin.text-xs
                  = t('.optional')
                = ai_badge(address_fields.object.unit, 'property.address.unit')
              = address_fields.number_field :unit, class: "deal-creator-input-text "
          .flex.flex-col.sm:flex-row.gap-6
            .flex-1
              = address_fields.label :city, t('.city'), class: "deal-creator-label" do
                = t('.city')
                = ai_badge(address_fields.object.city, 'property.address.city')
              = address_fields.text_field :city, class: "deal-creator-input-text "
            .flex-1
              = address_fields.label :province, t('.province'), class: "deal-creator-label" do
                = t('.province')
                = ai_badge(address_fields.object.province, 'property.address.province')
              = address_fields.select :province, options_for_select(SelectOptions::CANADIAN_PROVIENCES, address_fields.object.province), {}, {class: 'deal-creator-select'  }
            .flex-1
              = address_fields.label :country, t('.country'), class: "deal-creator-label" do
                = t('.country')
                = ai_badge(address_fields.object.country, 'property.address.country')
              = address_fields.select :country, options_for_select(["Canada"], selected: 'Canada'), {}, { class: 'deal-creator-select', disabled: true}
              = address_fields.hidden_field :country, value: "Canada"
            .flex-1
              = address_fields.label :postal_code, t('.postal_code'), class: "deal-creator-label" do
                = t('.postal_code')
                = ai_badge(address_fields.object.postal_code, 'property.address.postal_code')
              = address_fields.text_field :postal_code, class: "deal-creator-input-text "

    = render partial: 'deals/partials/action_bar', locals: { f: f, back_action_path: deal_guarantor_index_path(@deal), show_save_action: true, skip_action_path: nil, submit: false }

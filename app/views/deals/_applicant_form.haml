        .flex.mb-4
          %button.py-2.px-3.border.rounded-lg.border-gray-200.text-gray-600{type: "button", "data-action" => "click->form#add"}
            = t('.add_liability')

    %section.mb-8{:class => "max-w-[420px]"}
      .mb-6
        = liabilities_fields.label :owe_taxes_to_goverment, t('.taxes_owned'), class: "deal-creator-label"
        = liabilities_fields.number_field :taxes, class: "deal-creator-input-text "
        %p.text-sm.leading-5.text-gray-500{:class => "mt-[6px]"} Enter 0 or the amount of it
      .mb-6
        = liabilities_fields.label :pay_child_support, t('.child_support'), class: "deal-creator-label"
        = liabilities_fields.number_field  :child_support, class: "deal-creator-input-text "
        %p.text-sm.leading-5.text-gray-500{:class => "mt-[6px]"}
          = t('.enter_zero')
      %div
        = liabilities_fields.label :declared_bankrupcy_consumer_proposition, t('.bankrupcty'), class: "deal-creator-label"
        .inline-flex.items-center.gap-2.mr-3
          = liabilities_fields.radio_button :bankruptcy, true, data: { action: "change->liabilities#toggleBankruptcy" }
          = liabilities_fields.label :bankruptcy, t('.yes'), class:"text-sm text-gray-500"
        .inline-flex.items-center.gap-2
          = liabilities_fields.radio_button :bankruptcy, false, data: { action: "change->liabilities#toggleBankruptcy" }
          = liabilities_fields.label :declared_bankrupcy_consumer_proposition_no, t('.no'), class:"text-sm text-gray-500"

    %section.mb-8.bg-gray-100.rounded-lg.p-6{class: "#{'hidden' unless @applicant.liabilities.bankruptcy?}", "data-liabilities-target": "bankruptcyStatusSection"}
      %div
        = liabilities_fields.label :bankruptcy_status, t('.bankrupcty_status'), class: "deal-creator-label"
        .inline-flex.items-center.gap-2.mr-3
          = liabilities_fields.radio_button :bankruptcy_status, true, data: { action: "change->liabilities#toggleBankruptcyDetails" }
          = liabilities_fields.label :bankruptcy_status, t('.active'), class:"text-sm text-gray-500"
        .inline-flex.items-center.gap-2
          = liabilities_fields.radio_button :bankruptcy_status, false, data: { action: "change->liabilities#toggleBankruptcyDetails" }
          = liabilities_fields.label :bankruptcy_status, t('.resolved'), class:"text-sm text-gray-500"

      %section.mt-4{class: "#{'hidden' unless @applicant.liabilities.bankruptcy_active?}", "data-liabilities-target": "bankruptcyDetailsSection"}
        .flex.gap-6.flex-col.sm:flex-row.sm:items-center
          .flex-1
            = liabilities_fields.label :expected_release_date, t('.expected_release_date'), class: "deal-creator-label"
            = liabilities_fields.text_field :expected_release_date, class: 'deal-creator-select datepicker'
            %p.text-sm.leading-5.text-gray-500{:class => "mt-[6px]"}
              = t('.enter_approximate_date')
          .flex-1
            = liabilities_fields.label :cost_of_release, t('.cost_of_release'), class: "deal-creator-label"
            = liabilities_fields.text_field :cost_of_release, class: "deal-creator-input-text"
            %p.text-sm.leading-5.text-gray-500{:class => "mt-[6px]"}
              = t('.enter_approximate_cost')

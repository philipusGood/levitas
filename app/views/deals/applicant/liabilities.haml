.mb-40
  %h1.deal-creator-step-title
    = t('.title')
  %p.deal-creator-step-description
    = t('.leading')
  = render 'devise/shared/error_messages', resource: @liabilities
  = form_for @liabilities, url: wizard_path, method: :put, data: { turbo: false, controller: 'liabilities' } do |f|
    %section.mb-8{data: { controller: "form"} }
      %div
        %template{"data-form-target" => "template"}
          = f.fields_for "debt_obligations[]", Deal::Liabilities::DebtObligation.new({ balance_remaining: 0, monthly_payment: 0, type: 1}) do |debt_obligation_fields|
            .item
              .flex.flex-col.sm:flex-row.gap-6.mb-6
                .flex-1
                  = debt_obligation_fields.label :type, t('.loan_type'), class: "deal-creator-label"
                  = debt_obligation_fields.select :type, options_for_select(SelectOptions::LOAN_TYPES, debt_obligation_fields.object.type), {}, {class: 'deal-creator-select', "data-form-target" => "incomeType", "data-action" => "change->form#incomeSelected"}
                .flex-1
                  = debt_obligation_fields.label :balance_remaining, t('.balance_remaining'), class: "deal-creator-label"
                  = debt_obligation_fields.number_field :balance_remaining, class: "deal-creator-input-text"
                .flex-1
                  = debt_obligation_fields.label :monthly_payment, t('.monthly_payment'), class: "deal-creator-label"
                  = debt_obligation_fields.number_field :monthly_payment, class: "deal-creator-input-text"
                %div.flex.justify-center.self-end.pb-2
                  %button{type: "button", "data-action" => "click->form#remove"}
                    %svg{:fill => "none", :height => "24", :viewbox => "0 0 20 20", :width => "24", :xmlns => "http://www.w3.org/2000/svg"}
                      %path{"clip-rule" => "evenodd", :d => "M9 2C8.81434 2.0001 8.63237 2.05188 8.47447 2.14955C8.31658 2.24722 8.18899 2.38692 8.106 2.553L7.382 4H4C3.73478 4 3.48043 4.10536 3.29289 4.29289C3.10536 4.48043 3 4.73478 3 5C3 5.26522 3.10536 5.51957 3.29289 5.70711C3.48043 5.89464 3.73478 6 4 6V16C4 16.5304 4.21071 17.0391 4.58579 17.4142C4.96086 17.7893 5.46957 18 6 18H14C14.5304 18 15.0391 17.7893 15.4142 17.4142C15.7893 17.0391 16 16.5304 16 16V6C16.2652 6 16.5196 5.89464 16.7071 5.70711C16.8946 5.51957 17 5.26522 17 5C17 4.73478 16.8946 4.48043 16.7071 4.29289C16.5196 4.10536 16.2652 4 16 4H12.618L11.894 2.553C11.811 2.38692 11.6834 2.24722 11.5255 2.14955C11.3676 2.05188 11.1857 2.0001 11 2H9ZM7 8C7 7.73478 7.10536 7.48043 7.29289 7.29289C7.48043 7.10536 7.73478 7 8 7C8.26522 7 8.51957 7.10536 8.70711 7.29289C8.89464 7.48043 9 7.73478 9 8V14C9 14.2652 8.89464 14.5196 8.70711 14.7071C8.51957 14.8946 8.26522 15 8 15C7.73478 15 7.48043 14.8946 7.29289 14.7071C7.10536 14.5196 7 14.2652 7 14V8ZM12 7C11.7348 7 11.4804 7.10536 11.2929 7.29289C11.1054 7.48043 11 7.73478 11 8V14C11 14.2652 11.1054 14.5196 11.2929 14.7071C11.4804 14.8946 11.7348 15 12 15C12.2652 15 12.5196 14.8946 12.7071 14.7071C12.8946 14.5196 13 14.2652 13 14V8C13 7.73478 12.8946 7.48043 12.7071 7.29289C12.5196 7.10536 12.2652 7 12 7Z", :fill => "#DC2626", "fill-rule" => "evenodd"}

        %h2.deal-creator-section-subtitle
          = t('.debt_related_obligations')
          = ai_badge_collection(@liabilities.debt_obligations.map(&:serialize), 'applicant.liabilities.debt_obligations')
        %div{"data-form-target" => "items"}
          - @liabilities.debt_obligations&.each_with_index do |debt_obligation, index|
            = render 'devise/shared/error_messages', resource: debt_obligation
            = f.fields_for "debt_obligations[]", debt_obligation do |debt_obligation_fields|
              .item
                .flex.flex-col.sm:flex-row.gap-6.mb-6
                  .flex-1
                    = debt_obligation_fields.label :type, t('.loan_type'), class: "deal-creator-label"
                    = debt_obligation_fields.select :type, options_for_select(SelectOptions::LOAN_TYPES, debt_obligation_fields.object.type), {}, {class: 'deal-creator-select', "data-form-target" => "incomeType", "data-action" => "change->form#incomeSelected"}
                  .flex-1
                    = debt_obligation_fields.label :balance_remaining, t('.balance_remaining'), class: "deal-creator-label"
                    = debt_obligation_fields.number_field :balance_remaining, class: "deal-creator-input-text"
                  .flex-1
                    = debt_obligation_fields.label :monthly_payment, t('.monthly_payment'), class: "deal-creator-label"
                    = debt_obligation_fields.number_field :monthly_payment, class: "deal-creator-input-text"
                  %div.flex.justify-center.self-end.pb-2
                    %button{type: "button", "data-action" => "click->form#remove" }
                      %svg{:fill => "none", :height => "24", :viewbox => "0 0 20 20", :width => "24", :xmlns => "http://www.w3.org/2000/svg"}
                        %path{"clip-rule" => "evenodd", :d => "M9 2C8.81434 2.0001 8.63237 2.05188 8.47447 2.14955C8.31658 2.24722 8.18899 2.38692 8.106 2.553L7.382 4H4C3.73478 4 3.48043 4.10536 3.29289 4.29289C3.10536 4.48043 3 4.73478 3 5C3 5.26522 3.10536 5.51957 3.29289 5.70711C3.48043 5.89464 3.73478 6 4 6V16C4 16.5304 4.21071 17.0391 4.58579 17.4142C4.96086 17.7893 5.46957 18 6 18H14C14.5304 18 15.0391 17.7893 15.4142 17.4142C15.7893 17.0391 16 16.5304 16 16V6C16.2652 6 16.5196 5.89464 16.7071 5.70711C16.8946 5.51957 17 5.26522 17 5C17 4.73478 16.8946 4.48043 16.7071 4.29289C16.5196 4.10536 16.2652 4 16 4H12.618L11.894 2.553C11.811 2.38692 11.6834 2.24722 11.5255 2.14955C11.3676 2.05188 11.1857 2.0001 11 2H9ZM7 8C7 7.73478 7.10536 7.48043 7.29289 7.29289C7.48043 7.10536 7.73478 7 8 7C8.26522 7 8.51957 7.10536 8.70711 7.29289C8.89464 7.48043 9 7.73478 9 8V14C9 14.2652 8.89464 14.5196 8.70711 14.7071C8.51957 14.8946 8.26522 15 8 15C7.73478 15 7.48043 14.8946 7.29289 14.7071C7.10536 14.5196 7 14.2652 7 14V8ZM12 7C11.7348 7 11.4804 7.10536 11.2929 7.29289C11.1054 7.48043 11 7.73478 11 8V14C11 14.2652 11.1054 14.5196 11.2929 14.7071C11.4804 14.8946 11.7348 15 12 15C12.2652 15 12.5196 14.8946 12.7071 14.7071C12.8946 14.5196 13 14.2652 13 14V8C13 7.73478 12.8946 7.48043 12.7071 7.29289C12.5196 7.10536 12.2652 7 12 7Z", :fill => "#DC2626", "fill-rule" => "evenodd"}

        .flex.mb-4
          %button.py-2.px-3.border.rounded-lg.border-gray-200.text-gray-600{type: "button", "data-action" => "click->form#add", id: "add-liability"}
            = t('.add_liability')

    %section.mb-8{:class => "max-w-[420px]"}
      .mb-6
        = f.label :owe_taxes_to_goverment, t('.taxes_owned'), class: "deal-creator-label" do
          = t('.taxes_owned')
          = ai_badge(f.object.taxes, 'applicant.liabilities.taxes')
        = f.number_field :taxes, class: "deal-creator-input-text "
        %p.text-sm.leading-5.text-gray-500{:class => "mt-[6px]"} Enter 0 or the amount of it
      .mb-6
        = f.label :pay_child_support, t('.child_support'), class: "deal-creator-label" do
          = t('.child_support')
          = ai_badge(f.object.child_support, 'applicant.liabilities.child_support')
        = f.number_field  :child_support, class: "deal-creator-input-text "
        %p.text-sm.leading-5.text-gray-500{:class => "mt-[6px]"}
          = t('.enter_zero')
      %div
        = f.label :declared_bankrupcy_consumer_proposition, t('.bankrupcty'), class: "deal-creator-label" do
          = t('.bankrupcty')
          = ai_badge(f.object.bankruptcy, 'applicant.liabilities.bankruptcy')
        .inline-flex.items-center.gap-2.mr-3
          = f.radio_button :bankruptcy, true, data: { action: "change->liabilities#toggleBankruptcy" }
          = f.label :bankruptcy, t('.yes'), class:"text-sm text-gray-500"
        .inline-flex.items-center.gap-2
          = f.radio_button :bankruptcy, false, data: { action: "change->liabilities#toggleBankruptcy" }
          = f.label :declared_bankrupcy_consumer_proposition_no, t('.no'), class:"text-sm text-gray-500"

    %section.mb-8.bg-gray-100.rounded-lg.p-6{class: "#{'hidden' unless @liabilities.bankruptcy?}", "data-liabilities-target": "bankruptcyStatusSection"}
      %div
        = f.label :bankruptcy_status, t('.bankrupcty_status'), class: "deal-creator-label"
        .inline-flex.items-center.gap-2.mr-3
          = f.radio_button :bankruptcy_status, true, data: { action: "change->liabilities#toggleBankruptcyDetails" }
          = f.label :bankruptcy_status, t('.active'), class:"text-sm text-gray-500"
        .inline-flex.items-center.gap-2
          = f.radio_button :bankruptcy_status, false, data: { action: "change->liabilities#toggleBankruptcyDetails" }
          = f.label :bankruptcy_status, t('.resolved'), class:"text-sm text-gray-500"

      %section.mt-4{class: "#{'hidden' unless @liabilities.bankruptcy_active?}", "data-liabilities-target": "bankruptcyDetailsSection"}
        .flex.gap-6.flex-col.sm:flex-row.sm:items-center
          .flex-1
            = f.label :expected_release_date, t('.expected_release_date'), class: "deal-creator-label"
            = f.text_field :expected_release_date, class: 'deal-creator-select datepicker'
            %p.text-sm.leading-5.text-gray-500{:class => "mt-[6px]"}
              = t('.enter_approximate_date')
          .flex-1
            = f.label :cost_of_release, t('.cost_of_release'), class: "deal-creator-label"
            = f.text_field :cost_of_release, class: "deal-creator-input-text"
            %p.text-sm.leading-5.text-gray-500{:class => "mt-[6px]"}
              = t('.enter_approximate_cost')

    = render partial: 'deals/partials/action_bar', locals: { f: f, back_action_path: deal_main_applicant_path(@deal, 'assets'), show_save_action: true, skip_action_path: nil, submit: false }
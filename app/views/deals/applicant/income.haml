.mb-40
  %h1.deal-creator-step-title
    = t('.title')
  %p.deal-creator-step-description
    = t('.leading')
  = render 'devise/shared/error_messages', resource: @employer
  = form_for @employer, url: wizard_path, method: :put, data: { turbo: false, controller: :form } do |f|
    %section.mb-8
      %h2.deal-creator-section-title
        = t('.employer_information')
        %span.font-thin.text-xs
          = t('.optional')
      .py-6
        .flex.flex-col.sm:flex-row.gap-6.mb-6
          .flex-1
            = f.label :name, class: "deal-creator-label" do
              = t('.employer_name')
              = ai_badge(f.object.name, 'applicant.employer.name')
            = f.text_field :name, class: "deal-creator-input-text "
          .flex-1
            = f.label :job_title, class: "deal-creator-label" do
              = t('.job_title')
              = ai_badge(f.object.job_title, 'applicant.employer.job_title')
            = f.text_field :job_title, class: "deal-creator-input-text "
        .flex.flex-col.sm:flex-row.gap-6.mb-6
          .flex-1
            = f.label :industry_type, t('.industry_type'), class: "deal-creator-label" do
              = t('.industry_type')
              = ai_badge(f.object.industry_type, 'applicant.employer.industry_type')
            = f.select :industry_type, options_for_select(SelectOptions::INDUSTRY_TYPE, f.object.industry_type), { include_blank: ''}, {class: 'deal-creator-select'}
          .flex-1
            = f.label :employment_type, t('.employment_type'), class: "deal-creator-label" do
              = t('.employment_type')
              = ai_badge(f.object.employment_type, 'applicant.employer.employment_type')
            = f.select :employment_type, options_for_select(SelectOptions::EMPLOYMENT_TYPE, f.object.employment_type), { include_blank: ''}, {class: 'deal-creator-select'}
        %div
          = f.label :employment_duration, t('.duration_of_employment'), class: "deal-creator-label" do
            = t('.duration_of_employment')
            = ai_badge(f.object.duration_years, 'applicant.employer.duration_years') || ai_badge(f.object.duration_months, 'applicant.employer.duration_months')
          .flex.gap-4
            .flex.gap-1.justify-center.items-center.py-2.px-3.rounded.border.border-gray-300{:class => "max-w-[117px] h-[40px]"}
              = f.text_field  :duration_years, class: "w-full p-0 border-0 outline-none"
              %span.text-xs.text-gray-800.font-medium
                = t('.years')
            .flex.gap-1.justify-center.items-center.py-2.px-3.rounded.border.border-gray-300{:class => "max-w-[117px] h-[40px]"}
              = f.text_field  :duration_months, class: "w-full p-0 border-0 outline-none"
              %span.text-xs.text-gray-800.font-medium
                = t('.months')

    %div
      %template{"data-form-target" => "template"}
        = f.fields_for "income[]", Deal::Income::Item.new({ amount: 0}) do |income_fields|
          .item
            .flex.flex-col.sm:flex-row.gap-6.mb-6
              .flex-1
                = income_fields.label :type, t('.income_type'), class: "deal-creator-label"
                = income_fields.select :type, options_for_select(SelectOptions::INCOME_TYPE, income_fields.object.type), {}, {class: 'deal-creator-select', "data-form-target" => "incomeType", "data-action" => "change->form#incomeSelected"}
              .flex-1
                = income_fields.label :period, t('.period'), class: "deal-creator-label"
                = income_fields.select :period, options_for_select(SelectOptions::INCOME_PERIOD, income_fields.object.period), {}, {class: 'deal-creator-select'}
              .flex-1
                = income_fields.label :amount, t('.amount'), class: "deal-creator-label"
                = income_fields.number_field :amount, class: "deal-creator-input-text"
              %div.flex.justify-center.self-end.pb-2
                %button{type: "button", "data-action" => "click->form#remove"}
                  %svg{:fill => "none", :height => "24", :viewbox => "0 0 20 20", :width => "24", :xmlns => "http://www.w3.org/2000/svg"}
                    %path{"clip-rule" => "evenodd", :d => "M9 2C8.81434 2.0001 8.63237 2.05188 8.47447 2.14955C8.31658 2.24722 8.18899 2.38692 8.106 2.553L7.382 4H4C3.73478 4 3.48043 4.10536 3.29289 4.29289C3.10536 4.48043 3 4.73478 3 5C3 5.26522 3.10536 5.51957 3.29289 5.70711C3.48043 5.89464 3.73478 6 4 6V16C4 16.5304 4.21071 17.0391 4.58579 17.4142C4.96086 17.7893 5.46957 18 6 18H14C14.5304 18 15.0391 17.7893 15.4142 17.4142C15.7893 17.0391 16 16.5304 16 16V6C16.2652 6 16.5196 5.89464 16.7071 5.70711C16.8946 5.51957 17 5.26522 17 5C17 4.73478 16.8946 4.48043 16.7071 4.29289C16.5196 4.10536 16.2652 4 16 4H12.618L11.894 2.553C11.811 2.38692 11.6834 2.24722 11.5255 2.14955C11.3676 2.05188 11.1857 2.0001 11 2H9ZM7 8C7 7.73478 7.10536 7.48043 7.29289 7.29289C7.48043 7.10536 7.73478 7 8 7C8.26522 7 8.51957 7.10536 8.70711 7.29289C8.89464 7.48043 9 7.73478 9 8V14C9 14.2652 8.89464 14.5196 8.70711 14.7071C8.51957 14.8946 8.26522 15 8 15C7.73478 15 7.48043 14.8946 7.29289 14.7071C7.10536 14.5196 7 14.2652 7 14V8ZM12 7C11.7348 7 11.4804 7.10536 11.2929 7.29289C11.1054 7.48043 11 7.73478 11 8V14C11 14.2652 11.1054 14.5196 11.2929 14.7071C11.4804 14.8946 11.7348 15 12 15C12.2652 15 12.5196 14.8946 12.7071 14.7071C12.8946 14.5196 13 14.2652 13 14V8C13 7.73478 12.8946 7.48043 12.7071 7.29289C12.5196 7.10536 12.2652 7 12 7Z", :fill => "#DC2626", "fill-rule" => "evenodd"}

      %h2.deal-creator-section-title
        = t('.title')
        = ai_badge_collection(@employer.income, 'applicant.employer.income')
      %div{"data-form-target" => "items"}
        - @employer.income&.items&.each_with_index do |income, index|
          = render 'devise/shared/error_messages', resource: income
          = f.fields_for "income[]", income do |income_fields|
            .item
              .flex.flex-col.sm:flex-row.gap-6.mb-6
                .flex-1
                  = income_fields.label :type, t('.income_type'), class: "deal-creator-label"
                  = income_fields.select :type, options_for_select(SelectOptions::INCOME_TYPE, income_fields.object.type), {}, {class: 'deal-creator-select', "data-form-target" => "incomeType", "data-action" => "change->form#incomeSelected"}
                .flex-1
                  = income_fields.label :period, t('.period'), class: "deal-creator-label"
                  = income_fields.select :period, options_for_select(SelectOptions::INCOME_PERIOD, income_fields.object.period), {}, {class: 'deal-creator-select'}
                .flex-1
                  = income_fields.label :amount, t('.amount'), class: "deal-creator-label"
                  = income_fields.number_field :amount, class: "deal-creator-input-text"
                %div.flex.justify-center.self-end.pb-2
                  %button{type: "button", "data-action" => "click->form#remove", class: "#{'invisible' if index == 0}"}
                    %svg{:fill => "none", :height => "24", :viewbox => "0 0 20 20", :width => "24", :xmlns => "http://www.w3.org/2000/svg"}
                      %path{"clip-rule" => "evenodd", :d => "M9 2C8.81434 2.0001 8.63237 2.05188 8.47447 2.14955C8.31658 2.24722 8.18899 2.38692 8.106 2.553L7.382 4H4C3.73478 4 3.48043 4.10536 3.29289 4.29289C3.10536 4.48043 3 4.73478 3 5C3 5.26522 3.10536 5.51957 3.29289 5.70711C3.48043 5.89464 3.73478 6 4 6V16C4 16.5304 4.21071 17.0391 4.58579 17.4142C4.96086 17.7893 5.46957 18 6 18H14C14.5304 18 15.0391 17.7893 15.4142 17.4142C15.7893 17.0391 16 16.5304 16 16V6C16.2652 6 16.5196 5.89464 16.7071 5.70711C16.8946 5.51957 17 5.26522 17 5C17 4.73478 16.8946 4.48043 16.7071 4.29289C16.5196 4.10536 16.2652 4 16 4H12.618L11.894 2.553C11.811 2.38692 11.6834 2.24722 11.5255 2.14955C11.3676 2.05188 11.1857 2.0001 11 2H9ZM7 8C7 7.73478 7.10536 7.48043 7.29289 7.29289C7.48043 7.10536 7.73478 7 8 7C8.26522 7 8.51957 7.10536 8.70711 7.29289C8.89464 7.48043 9 7.73478 9 8V14C9 14.2652 8.89464 14.5196 8.70711 14.7071C8.51957 14.8946 8.26522 15 8 15C7.73478 15 7.48043 14.8946 7.29289 14.7071C7.10536 14.5196 7 14.2652 7 14V8ZM12 7C11.7348 7 11.4804 7.10536 11.2929 7.29289C11.1054 7.48043 11 7.73478 11 8V14C11 14.2652 11.1054 14.5196 11.2929 14.7071C11.4804 14.8946 11.7348 15 12 15C12.2652 15 12.5196 14.8946 12.7071 14.7071C12.8946 14.5196 13 14.2652 13 14V8C13 7.73478 12.8946 7.48043 12.7071 7.29289C12.5196 7.10536 12.2652 7 12 7Z", :fill => "#DC2626", "fill-rule" => "evenodd"}

      .flex.mb-4
        %button.py-2.px-3.border.rounded-lg.border-gray-200.text-gray-600{type: "button", "data-action" => "click->form#add"}
          = t('.add_other_income')

    = f.fields_for :address, @employer.address do |address_fields|
      %section.mb-8{"data-form-target": "employerAddress"}
        %h2.deal-creator-section-title
          = t('.employer_address')
          %span.font-thin.text-xs
            = t('.optional')
        .py-6
          .flex.gap-6.mb-6
            .flex-1
              = address_fields.label :street, t('.street'), class: "deal-creator-label" do
                = t('.street')
                = ai_badge(f.object.address.street, 'applicant.employer.address.street')
              = address_fields.text_field :street, class: "deal-creator-input-text"
            .flex-1{:class => "max-w-[250px]"}
              = address_fields.label :unit, class: "deal-creator-label" do
                = t('.unit')
                %span.font-thin.text-xs
                  = t('.optional')
                = ai_badge(f.object.address.unit, 'applicant.employer.address.unit')
              = address_fields.number_field :unit, class: "deal-creator-input-text"
          .flex.flex-col.sm:flex-row.gap-6
            .flex-1
              = address_fields.label :city, t('.city'), class: "deal-creator-label" do
                = t('.city')
                = ai_badge(f.object.address.city, 'applicant.employer.address.city')
              = address_fields.text_field :city, class: "deal-creator-input-text"
            .flex-1
              = address_fields.label :province, t('.province'), class: "deal-creator-label" do
                = t('.province')
                = ai_badge(f.object.address.province, 'applicant.employer.address.province')
              = address_fields.select :province, options_for_select(SelectOptions::CANADIAN_PROVIENCES, address_fields.object.province), {}, {class: 'deal-creator-select'  }
            .flex-1
              = address_fields.label :country, t('.country'), class: "deal-creator-label" do
                = t('.country')
                = ai_badge(f.object.address.country, 'applicant.employer.address.country')
              = address_fields.select :country, options_for_select(["Canada"], selected: 'Canada'), {}, { class: 'deal-creator-select' }
            .flex-1
              = address_fields.label :postal_code, t('.postal_code'), class: "deal-creator-label" do
                = t('.postal_code')
                = ai_badge(f.object.address.postal_code, 'applicant.employer.address.postal_code')
              = address_fields.text_field :postal_code, class: "deal-creator-input-text"
      %section.mb-8{"data-form-target": "employerContact"}
        %h2.deal-creator-section-title
          = t('.employer_contact')
          %span.font-thin.text-xs
            = t('.optional')
        .py-6
          .flex.flex-col.sm:flex-row.gap-6.mb-6
            .flex-1
              = f.label :phone_number, t('.phone_number'), class: "deal-creator-label" do
                = t('.phone_number')
                = ai_badge(f.object.phone_number, 'applicant.employer.phone_number')
              = f.telephone_field  :phone_number, class: "deal-creator-input-text"
            .flex-1
              = f.label :ext, t('.ext'), class: "deal-creator-label" do
                = t('.ext')
                = ai_badge(f.object.ext, 'applicant.employer.ext')
              = f.text_field :ext, class: "deal-creator-input-text"
            .flex-1
              = f.label :fax, t('.fax'), class: "deal-creator-label" do
                = t('.fax')
                = ai_badge(f.object.fax, 'applicant.employer.fax')
              = f.telephone_field :fax, class: "deal-creator-input-text"
          .flex.gap-6
            .flex-1{:class => "sm:max-w-[28%]"}
              = f.label :email, t('.email_address'), class: "deal-creator-label" do
                = t('.email_address')
                = ai_badge(f.object.email, 'applicant.employer.email')
              = f.email_field :email, class: "deal-creator-input-text"

    = render partial: 'deals/partials/action_bar', locals: { f: f, back_action_path: wizard_step_path(@deal, 'information'), show_save_action: true, skip_action_path: nil, submit: false}

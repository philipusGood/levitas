= turbo_frame_tag :modal do
  .relative.z-40{ "aria-labelledby": "modal-title", "role": "dialog", "aria-modal": "true"}
    .fixed.inset-0.bg-gray-500.bg-opacity-75
    .fixed.inset-0.z-10.p-6.md:p-10.overflow-y-auto
      .flex.min-h-full.items-center.justify-center.max-w-lg.mx-auto
        .levitas-modal{data: {controller: "modal invite-lenders"}}
          .header.border-none
            %span.title= t('.capital_commited')
            = button_tag type: :button, class: "min-w-[1.5rem] min-h-[1.5rem]" do
              = image_tag "icons/x.svg", {"data-action": "click->modal#close"}
          .body
            .grid.grid-cols-3.gap-3
              .flex.flex-col.gap-1.p-2.bg-gray-50.text-gray-600
                %span.flex-1.text-sm.opacity-70= t('.target')
                .flex.flex-1.font-bold= number_to_currency_without_cents(@deal.target, precision: 0)
              .flex.flex-col.gap-1.p-2.bg-gray-50.text-gray-600
                %span.flex-1.text-sm.opacity-70= t('.commited')
                .flex.flex-1.font-bold= number_to_currency_without_cents(@deal.commited_capital, precision: 0)
              .flex.flex-col.gap-1.p-2.bg-gray-50.text-gray-600
                %span.flex-1.text-sm.opacity-70= t('.closing_date')
                .flex.flex-1.font-bold= Date.parse(@deal.property.approximate_closing_date).strftime("%b %d, %Y")
            .flex.flex-col.gap-1.col-span-full
              .flex.justify-between
                %span.text-gray-500.text-xs= t('.progress')
                %span.text-gray-500.text-xs= number_to_percentage(@deal.funding_progress, precision: 0)
              %progress.deal-progress-bar{ value: @deal.funding_progress, max: 100, class: "#{'completed' if @deal.funding_completed?}"}}
            - unless @deal.deal_lenders.size.zero?
              %ul.grid.grid-cols-1.max-h-80.items-start.overflow-y-auto
                - @deal.deal_lenders.each do |l|
                  %li.grid.p-2.gap-3.items-center.justify-between{class: "grid-cols-[3rem_1fr_5.8125rem]"}
                    .flex.flex-none.items-center.justify-center.rounded-full.w-12.h-12.bg-blue-400{class: "#{'bg-gray-400' if l.commited_capital.zero?}"}
                      %span.text-white.font-bold= l.lender.short_full_name
                    .flex.flex-col.flex-1.gap-1.overflow-y-auto
                      %span.text-gray-600.font-bold= l.lender.full_name
                      %p.text-gray-400.text-sm= l.lender.email
                    - unless l.commited_capital.zero?
                      %span.text-sm.text-gray-600.font-bold.text-end= number_to_currency_without_cents(l.commited_capital, precision: 0)
                    - if l.commited_capital.zero?
                      %span.text-blue-500.text-sm.font-bold.text-end= t('.resend_invite')

          .footer
            - if @deal.funding_completed?
              .flex.flex-auto.justify-center.items-center.-mx-6.-my-4.py-6.bg-emerald-50.text-emerald-500{class: "px-[1.625rem] rounded-b-[7px]"}
                %p.text-sm.font-bold= t('.funding_is_completed')
            - unless @deal.funding_completed?
              = link_to invite_lenders_modal_deal_path, class: "levitas-button primary wide", data: { "turbo-frame": "modal" } do
                = image_tag 'icons/mail.svg'
                %span= t('.invite_lenders')

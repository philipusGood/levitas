= turbo_stream.update :modal do
  .relative.z-40{ "aria-labelledby": "modal-title", "role": "dialog", "aria-modal": "true"}
    .fixed.inset-0.bg-gray-500.bg-opacity-75
    .fixed.inset-0.z-40.p-6.md:p-10.overflow-y-auto
      .flex.min-h-full.items-center.justify-center.max-w-5xl.mx-auto
        = form_with url: commit_capital_deal_lender_path(deal_id: @deal.id, id: current_user.id), method: :post, class: "levitas-modal", data: {controller: "modal lender-funding"} do |f|
          .header.max-md:flex-col
            %span.title= t('.confirm_and_fund_deal')
            .flex.gap-4
              .step.completed
                .flex.items-center.justify-center.rounded-full.bg-green-50.w-8.h-8{class: "p-1.5"}
                  = image_tag "icons/check-green.svg"
                = t('.investment')
              .step.current
                .number.rounded-full 2
                = t('.confirm')
          .body.relative{class: "max-h-[36.75rem]"}
            .absolute.left-0.bottom-0.h-16.w-full.bg-gradient-to-t.from-white
            .flex.flex-col.gap-3.overflow-y-auto.max-h-full
              = t('.lender_fund_user_agreement.html')
          .footer.flex-col
            .flex.gap-2.items-center
              = f.check_box :accept_policy, class: "rounded border-gray-400 text-blue-500", data: { "lender-funding-target": "checkbox", action: "change->lender-funding#check" }
              = f.label :accept_policy, t('.checkbox_label_html'), class: "text-sm text-gray-700"
            .flex.md:flex-1.justify-between.items-start.max-md:flex-col.gap-4
              .flex.gap-3
                %span.max-md:hidden{data: {action: "click->modal#close"}}
                  = levitas_button :button, t('.cancel'), 'danger', nil, :large
                = link_to t('.change_investment'), review_investment_modal_deal_lender_path(deal_id: @deal.id, id: current_user.id), class: 'levitas-button large max-md:hidden'
              .flex.gap-3.md:items-center.max-md:flex-col.max-md:w-full
                = f.hidden_field :amount, value: investment
                = f.hidden_field :full_name, value: current_user.full_name, data: { "lender-funding-target": "name" }
                = f.text_field :confirm_name, placeholder: t('.enter_full_name'), class: "levitas-form-input", data: { "lender-funding-target": "nameInput", action: "input->lender-funding#check" }
                .flex.gap-3
                  = button_tag t('.cancel'), type: :button, class: "levitas-button danger large md:hidden", data: {action: "click->modal#close"}
                  = link_to t('.change_investment'), review_investment_modal_deal_lender_path(deal_id: @deal.id, id: current_user.id), class: 'levitas-button large md:hidden'
                = f.submit t('.confirm_and_fund_deal'), disabled: :disabled, class: "levitas-button primary large", data: { "lender-funding-target": "submit" }, id: "confirm-investment-btn"

= turbo_frame_tag :modal do
  .relative.z-40{ "aria-labelledby": "modal-title", "role": "dialog", "aria-modal": "true"}
    .fixed.inset-0.bg-gray-500.bg-opacity-75
    .fixed.inset-0.z-40.p-6.md:p-10.overflow-y-auto
      .flex.min-h-full.items-center.justify-center.max-w-5xl.mx-auto
        = form_with url: review_investment_modal_deal_lender_path(deal_id: @deal.id, id: current_user.id, step_2: true), method: :post, class: "levitas-modal", data: {controller: "modal lender-funding"} do |f|
          .header.max-md:flex-col
            %span.title= t('.enter_your_investment_amount')
            .flex.gap-4
              .step.current
                .number.rounded-full 1
                = t('.investment')
              .step
                .number.rounded-full 2
                = t('.confirm')
          .body{class: "max-h-[36.75rem]"}
            .flex.flex-col.px-2.gap-8.border-b.border-gray-200.pb-3
              %h2.section-title= t('.terms')
              .flex.flex-wrap.gap-3
                .terms-cell
                  %p.text-sm.opacity-70= t('.mortgage_principal')
                  %p.font-bold
                    = number_to_currency_without_cents(@deal.total_mortgage_principal)
                .terms-cell
                  %p.text-sm.opacity-70
                    = t('.term')
                  %p.font-bold
                    = deal_terms_in_words(@deal.terms.terms_to_years_months)
                .terms-cell
                  %p.text-sm.opacity-70
                    = "#{t('.interest_rate')}  + #{t('.lenders_fee')}"
                  %p.font-bold
                    = "#{number_to_percentage(@deal.terms.interest_rate, precision: 2, strip_insignificant_zeros: true)} + #{number_to_percentage(@deal.terms.lenders_fee, precision: 2, strip_insignificant_zeros: true)}"
                .terms-cell
                  %p.text-sm.opacity-70
                    = t('.amortization')
                  %p.font-bold
                    = @deal.terms.amortization_period
                .terms-cell
                  %p.text-sm.opacity-70
                    = t('.closing_date')
                  %p.font-bold
                    = Date.parse(@deal.property.approximate_closing_date).strftime("%b %d, %Y")
                .terms-cell
                  %p.text-sm.opacity-70
                    = t('.type')
                  %p.font-bold
                    = @deal.terms.type
            .flex.flex-col.md:flex-row.px-2.gap-3
              = render "deals/partials/score_gauge"
            .flex.flex-col{class: "gap-1.5"}
              = f.label :investment_amount, t('.investment_amount'), class: "text-sm text-gray-700 font-bold"
              = f.text_field :investment_amount, placeholder: "$125,000.00", pattern: "^[0-9]+(\.[0-9]{2})?$", data: { "lender-funding-target": "amountInput", action: "input->lender-funding#checkAmount" }, class: "levitas-form-input"
              %span.text-sm.text-gray-500= t('.minimum_investment') + ": $100,000.00"
            .flex.pb-28
              %span.text-sm.text-gray-500= t('.funds_distribution_msg')
          .footer
            .flex.md:flex-1.gap-3.justify-between
              %span{"data-action": "click->modal#close"}
                = levitas_button :button, t('.cancel'), 'danger', nil, :large
              = f.submit t('.continue'), disabled: 'disabled', class: "levitas-button primary large", data: {"lender-funding-target": "submit"}, id: "funding-continue"

= turbo_stream.update :modal do
  .relative.z-40{ "aria-labelledby": "modal-title", "role": "dialog", "aria-modal": "true"}
    .fixed.inset-0.bg-gray-500.bg-opacity-75
    .fixed.inset-0.z-10.p-6.md:p-10.overflow-y-auto
      .flex.min-h-full.items-center.justify-center.max-w-lg.mx-auto
        .levitas-modal
          .body
            .flex.flex-col.gap-3.justify-center.text-center
              .flex.flex-1.items-center.justify-center
                .flex.items-center.justify-center.p-7.rounded-full.border-2.border-green-500.bg-green-50.w-28.h-28
                  = image_tag "icons/check-green.svg"
              %span.text-2xl.font-bold.leading-9= t('.deal_terms_rejected')
              %p We will review your rejection details, and get back to you with a determination for this deal.
              .flex.justify-center
                %span{"data-action": "click->modal#reload"}
                  = levitas_button :button, t('.close'), nil, nil, :large

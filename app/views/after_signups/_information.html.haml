= render 'layouts/after_signup/sidebar'
%main.py-10.lg:pl-80
  .px-4.sm:px-6.lg:px-8
    = form_for @user, url: after_signup_path, method: :put do |f|
      .space-y-12.lg:px-32
        .pb-12
          %h2.text-2xl.leading-9.text-gray-900.font-serif= t('.information')
          = render 'devise/shared/error_messages', resource: @user 
          .mt-10.grid.grid-cols-1.gap-x-6.gap-y-8.sm:grid-cols-12
            %h3.col-span-full.text-xl.font-serif.leading-7.text-gray-900= t('.profile')
            .sm:col-span-3
              = f.label :title, t('.title'), class: 'form-label'
              .mt-2
                = f.select :title, options_for_select(SelectOptions::PROFILE_TITLES, f.object.title), {}, {class: 'form-select' }
            .sm:col-span-6.sm:col-start-1
              = f.label :first_name, t('.first_name'), class: 'form-label'
              .mt-2
                = f.text_field :first_name, class: 'form-input-text'
            .sm:col-span-6
              = f.label :middle_name, t('.middle_name'), class: 'form-label'
              .mt-2
                = f.text_field :middle_name, class: 'form-input-text'
            .sm:col-span-6.sm:col-start-1
              = f.label :last_name, t('.last_name'), class: 'form-label'
              .mt-2
                = f.text_field :last_name, class: 'form-input-text'
            .sm:col-span-6
              .flex.items-center
                = f.label :birth_date, t('.birth_date'), class: 'form-label'
                %span.text-xs.text-gray-600.ml-2 (YYYY-MM-DD)
              .mt-2
                = f.text_field :birth_date, class: 'form-input-date datepicker'
            %h3.col-span-full.text-xl.font-serif.leading-7.text-gray-900= t('.contact_information')
            .sm:col-span-6.sm:col-start-1
              = f.label :email, t('.email'), class: 'form-label'
              .mt-2
                = f.text_field :email, class: 'form-input-text-disabled', disabled: true
              %p.mt-1.text-xs.leading-6.text-gray-600= t('.message_under_email')
            .sm:col-span-6
              = f.label :phone_number, t('.phone_number'), class: 'form-label'
              .mt-2
                = f.text_field :phone_number, class: 'form-input-text'
            - if @user.lender?
              %h3.col-span-full.text-xl.font-serif.leading-7.text-gray-900= t('.corporation')
              .sm:col-span-6.sm:col-start-1
                = f.label :corporation_name, class: 'form-label' do
                  .container
                    .tooltip.mb-2
                      %span.flex.items-center
                        = t('.corporation_name')
                        %svg{:fill => "none", :height => "16", :viewbox => "0 0 16 16", :width => "16", :xmlns => "http://www.w3.org/2000/svg"}
                          %path{"clip-rule" => "evenodd", :d => "M14.3996 7.99961C14.3996 9.69699 13.7253 11.3249 12.5251 12.5251C11.3249 13.7253 9.69699 14.3996 7.99961 14.3996C6.30222 14.3996 4.67436 13.7253 3.47413 12.5251C2.27389 11.3249 1.59961 9.69699 1.59961 7.99961C1.59961 6.30222 2.27389 4.67436 3.47413 3.47413C4.67436 2.27389 6.30222 1.59961 7.99961 1.59961C9.69699 1.59961 11.3249 2.27389 12.5251 3.47413C13.7253 4.67436 14.3996 6.30222 14.3996 7.99961ZM7.99961 5.59961C7.85905 5.59947 7.72093 5.63637 7.59917 5.70659C7.4774 5.77682 7.37629 5.87788 7.30601 5.99961C7.25526 6.09391 7.1861 6.17706 7.10262 6.24414C7.01914 6.31121 6.92304 6.36084 6.82002 6.39009C6.71701 6.41934 6.60916 6.4276 6.50289 6.4144C6.39662 6.40119 6.29408 6.36679 6.20136 6.31322C6.10863 6.25965 6.0276 6.18801 5.96307 6.10254C5.89855 6.01708 5.85184 5.91953 5.82571 5.81568C5.79959 5.71182 5.79458 5.60378 5.81098 5.49796C5.82738 5.39213 5.86487 5.29068 5.92121 5.19961C6.18538 4.7421 6.59314 4.38454 7.08123 4.18238C7.56932 3.98022 8.11048 3.94476 8.62078 4.0815C9.13108 4.21823 9.58201 4.51952 9.90363 4.93865C10.2252 5.35777 10.3996 5.87131 10.3996 6.39961C10.3998 6.8961 10.246 7.38043 9.95942 7.78589C9.67287 8.19135 9.26767 8.498 8.79961 8.66361V8.79961C8.79961 9.01178 8.71532 9.21527 8.56529 9.36529C8.41527 9.51532 8.21178 9.59961 7.99961 9.59961C7.78744 9.59961 7.58395 9.51532 7.43392 9.36529C7.28389 9.21527 7.19961 9.01178 7.19961 8.79961V7.99961C7.19961 7.78744 7.28389 7.58395 7.43392 7.43392C7.58395 7.28389 7.78744 7.19961 7.99961 7.19961C8.21178 7.19961 8.41527 7.11532 8.56529 6.96529C8.71532 6.81527 8.79961 6.61178 8.79961 6.39961C8.79961 6.18744 8.71532 5.98395 8.56529 5.83392C8.41527 5.68389 8.21178 5.59961 7.99961 5.59961ZM7.99961 11.9996C8.21178 11.9996 8.41527 11.9153 8.56529 11.7653C8.71532 11.6153 8.79961 11.4118 8.79961 11.1996C8.79961 10.9874 8.71532 10.784 8.56529 10.6339C8.41527 10.4839 8.21178 10.3996 7.99961 10.3996C7.78744 10.3996 7.58395 10.4839 7.43392 10.6339C7.28389 10.784 7.19961 10.9874 7.19961 11.1996C7.19961 11.4118 7.28389 11.6153 7.43392 11.7653C7.58395 11.9153 7.78744 11.9996 7.99961 11.9996Z", :fill => "#3F3F46", "fill-rule" => "evenodd"}
                      .tooltip-content
                        %p.text-sm.text-white.font-medium{:class => "mb-[6px]"}
                        %p.text-xs.text-gray-400
                          This corporation will be used for your commitment documents when funding a mortgage"
                .mt-2
                  = f.text_field :corporation_name, class: 'form-input-text'
            %h3.col-span-full.text-xl.font-serif.leading-7.text-gray-900= t('.address')
            .sm:col-span-10.sm:col-start-1
              = f.label :address_street, t('.street'), class: 'form-label'
              .mt-2
                = f.text_field :address_street, class: 'form-input-text'
            .sm:col-span-2
              = f.label :address_unit, class: 'form-label' do
                = t('.unit')
                %span.font-thin.text-xs
                  = t('.optional')
              .mt-2
                = f.text_field :address_unit, class: 'form-input-text'
            .sm:col-span-3.sm:col-start-1
              = f.label :address_city, t('.city'), class: 'form-label'
              .mt-2
                = f.text_field :address_city, class: 'form-input-text'
            .sm:col-span-3
              = f.label :address_province, t('.province'),  class: 'form-label'
              .mt-2
                = f.select :address_province, options_for_select(SelectOptions::CANADIAN_PROVIENCES, f.object.address_province), {}, {class: 'form-select'}
            .sm:col-span-3
              = f.label :address_country, t('.country'), class: 'form-label'
              .mt-2
                = f.select :address_country, options_for_select([%w(Canada canada)]), {}, {class: 'form-select' }
            .sm:col-span-3
              = f.label :address_postal_code, t('.postal_code'), class: 'form-label'
              .mt-2
                = f.text_field :address_postal_code, class: 'form-input-text'

          - if @user.lender?
            %h3.col-span-full.text-xl.font-serif.leading-7.text-gray-900.mt-4
              = t('.accredited_investor')
            %section.inline-block.mb-8.mt-2
              .levitas-checkbox
                = f.check_box :accredited_investor
                = f.label :accredited_investor, t('.accept_accredited_investor')
      .container-controls
        %button.btn-next{:type => "submit"}
          = t('helpers.next_step')
          %svg.w-4.h-6{:fill => "none", :stroke => "currentColor", "stroke-width" => "1.5", :viewbox => "0 0 24 24", :xmlns => "http://www.w3.org/2000/svg"}
            %path{:d => "M8.25 4.5l7.5 7.5-7.5 7.5", "stroke-linecap" => "round", "stroke-linejoin" => "round"}

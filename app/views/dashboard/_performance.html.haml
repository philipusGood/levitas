%div.flex.flex-col.gap-8
  %h3.font-serif.font-bold.text-xl.text-gray-700= t('dashboard.index.performance')
  .flex.max-md:flex-col.gap-3
    .grid.grid-cols-1.gap-3.flex-1
      .flex.flex-col.self-stretch.items-start.gap-2.p-3.border.border-gray-100.rounded-lg.bg-white.md:px-4
        .flex.flex-col.self-stretch.items-start.gap-1.md:gap-2
          %p.font-sans.font-medium.md:font-bold.text-sm.text-gray-800.opacity-70= t('dashboard.index.active_deals')
          %p.font-serif.font-bold.text-2xl.text-gray-800
            = performance.total_active_deals
        .flex.flex-col.self-stretch.items-start.gap-3
          .flex.self-stretch.items-start{:class => 'gap-0.5'}
            - performance.status.each do |key, value|
              %span.select-none{:class => "deal-status-#{key} #{value.zero? ? 'hidden' : ''} w-[#{number_to_percentage((value * 100.0) / @user_deals.length, precision: 0)}] h-3 rounded"}
          .flex.flex-wrap.self-stretch.items-start.gap-4
            - performance.status.each do |key, value|
              .flex.flex-col.items-start.p-1{:class => 'gap-0.5'}
                %span.font-sans.font-medium.text-sm.text-gray-800.opacity-70
                  = t("dashboard.index.deal_status.#{key}")
                .flex.items-center.gap-1
                  .rounded-full.h-3.w-3.select-none{:class => "deal-status-#{key}"}
                  %span.font-serif.font-bold.text-gray-800
                    = value
    = render 'stats'

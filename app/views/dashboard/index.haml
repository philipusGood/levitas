              .flex.flex-col.p-2.content-center.justify-center.rounded-md{"data-action" => "click->deals#switchView", "data-deals-target" => "tableViewMenu", class: "#{(@deals_view.present? && @deals_view.eql?('table')) ? 'bg-gray-200 hover:cursor-auto' : 'bg-white hover:cursor-pointer'}"}
                %svg{xmlns: "http://www.w3.org/2000/svg", width: "16", height: "16", viewBox: "0 0 16 16", fill:"none", id: "table-view"}
                  %path{"fill-rule" => "evenodd", "clip-rule" => "evenodd", d: "M2.40039 3.20039C2.40039 2.98822 2.48468 2.78473 2.63471 2.63471C2.78473 2.48468 2.98822 2.40039 3.20039 2.40039H12.8004C13.0126 2.40039 13.216 2.48468 13.3661 2.63471C13.5161 2.78473 13.6004 2.98822 13.6004 3.20039C13.6004 3.41256 13.5161 3.61605 13.3661 3.76608C13.216 3.91611 13.0126 4.00039 12.8004 4.00039H3.20039C2.98822 4.00039 2.78473 3.91611 2.63471 3.76608C2.48468 3.61605 2.40039 3.41256 2.40039 3.20039ZM2.40039 6.40039C2.40039 6.18822 2.48468 5.98473 2.63471 5.83471C2.78473 5.68468 2.98822 5.60039 3.20039 5.60039H12.8004C13.0126 5.60039 13.216 5.68468 13.3661 5.83471C13.5161 5.98473 13.6004 6.18822 13.6004 6.40039C13.6004 6.61256 13.5161 6.81605 13.3661 6.96608C13.216 7.11611 13.0126 7.20039 12.8004 7.20039H3.20039C2.98822 7.20039 2.78473 7.11611 2.63471 6.96608C2.48468 6.81605 2.40039 6.61256 2.40039 6.40039ZM2.40039 9.60039C2.40039 9.38822 2.48468 9.18473 2.63471 9.03471C2.78473 8.88468 2.98822 8.80039 3.20039 8.80039H12.8004C13.0126 8.80039 13.216 8.88468 13.3661 9.03471C13.5161 9.18473 13.6004 9.38822 13.6004 9.60039C13.6004 9.81256 13.5161 10.016 13.3661 10.1661C13.216 10.3161 13.0126 10.4004 12.8004 10.4004H3.20039C2.98822 10.4004 2.78473 10.3161 2.63471 10.1661C2.48468 10.016 2.40039 9.81256 2.40039 9.60039ZM2.40039 12.8004C2.40039 12.5882 2.48468 12.3847 2.63471 12.2347C2.78473 12.0847 2.98822 12.0004 3.20039 12.0004H12.8004C13.0126 12.0004 13.216 12.0847 13.3661 12.2347C13.5161 12.3847 13.6004 12.5882 13.6004 12.8004C13.6004 13.0126 13.5161 13.216 13.3661 13.3661C13.216 13.5161 13.0126 13.6004 12.8004 13.6004H3.20039C2.98822 13.6004 2.78473 13.5161 2.63471 13.3661C2.48468 13.216 2.40039 13.0126 2.40039 12.8004Z", fill: "#52525B"}

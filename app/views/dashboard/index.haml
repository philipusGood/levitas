                  %a.flex.py-3.px-4.hover:bg-gray-200{href: dashboard_index_path({sort: SelectOptions::SORT_DEALS[:closing_date], order: 'asc'}), data: {action: "click->deals#orderDeals"}}= t('.deals_filter.sort.asc.closing_date')
                  %a.flex.py-3.px-4.hover:bg-gray-200{href: dashboard_index_path({sort: SelectOptions::SORT_DEALS[:closing_date], order: 'desc'}), data: {action: "click->deals#orderDeals"}}= t('.deals_filter.sort.desc.closing_date')

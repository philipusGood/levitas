:javascript
  posthog.identify(
    '#{current_user.email}',
    {name: '#{current_user.full_name}', role: '#{current_user.role}'}
  );

.flex.flex-col.gap-y-12{"data-controller" => "deals", "data-deals-selected-class" => "bg-gray-200", "data-deals-default-class" => "bg-white"}
  .flex.justify-between
    %h1.text-2xl.text-gray-700.font-serif.font-bold.leading-9
      = t('.greeting', name: current_user.first_name)

    - unless current_user.lender?
      %div
        = form_tag(deals_path, data: { turbo: false}) do
          = button_to deals_path, class: "inline-block px-4 py-2 text-base rounded-lg flex justify-center border border-[#E4E4E7] hover:cursor-pointer bg-blue-600 text-white", type: "submit", id: "create-deal" do
            = t('.create_deal')
            %svg{fill: "none", height: "24", viewbox: "0 0 24 24", width: "24", xmlns: "http://www.w3.org/2000/svg"}
              %path{"clip-rule" => "evenodd", d: "M12 7C12.2652 7 12.5196 7.10536 12.7071 7.29289C12.8946 7.48043 13 7.73478 13 8V11H16C16.2652 11 16.5196 11.1054 16.7071 11.2929C16.8946 11.4804 17 11.7348 17 12C17 12.2652 16.8946 12.5196 16.7071 12.7071C16.5196 12.8946 16.2652 13 16 13H13V16C13 16.2652 12.8946 16.5196 12.7071 16.7071C12.5196 16.8946 12.2652 17 12 17C11.7348 17 11.4804 16.8946 11.2929 16.7071C11.1054 16.5196 11 16.2652 11 16V13H8C7.73478 13 7.48043 12.8946 7.29289 12.7071C7.10536 12.5196 7 12.2652 7 12C7 11.7348 7.10536 11.4804 7.29289 11.2929C7.48043 11.1054 7.73478 11 8 11H11V8C11 7.73478 11.1054 7.48043 11.2929 7.29289C11.4804 7.10536 11.7348 7 12 7Z", fill: "white", "fill-rule" => "evenodd"}


  - if @user_deals.empty?
    .flex.flex-col.justify-center.items-center.h-full
      %svg{fill: "none", height: "120", viewbox: "0 0 120 120", width: "120", xmlns: "http://www.w3.org/2000/svg"}
        %rect{fill: "#E4E4E7", height: "120", rx: "60", width: "120"}
      %h3.mt-2.text-sm.font-semibold.text-gray-900.text-xl.mt-4
        = t('.no_active_deals')
      - if current_user.lender?
        .mt-6
          = button_to marketplace_index_path, method: :get, params: { visibility: 'public' }, class: "inline-block px-4 py-2 text-base rounded-lg flex justify-center border border-[#E4E4E7] hover:cursor-pointer bg-blue-600 text-white" do
            = t('.explore_marketplace')
      - else
        .mt-6
          = form_tag(deals_path, data: { turbo: false}) do
            = button_to deals_path, class: "inline-block px-4 py-2 text-base rounded-lg flex justify-center border border-[#E4E4E7] hover:cursor-pointer bg-blue-600 text-white", type: "submit" do
              = t('.create_deal')
  - else
    - unless current_user.admin?
      = render 'performance'
    .flex.flex-col.items-start.self-stretch.gap-8
      .flex.justify-between.items-center.self-stretch
        %p.font-serif.font-bold.text-xl.text-gray-700{:class => "leading-[30px]"}= t('.my_deals')
        .flex.items-start.gap-3.md:gap-6.font-sans.text-gray-600
          = form_with url: dashboard_index_path(request.query_parameters), method: :get, data: {"deals-target": "statusFilterForm"} do|f|
            .flex.items-start.self-stretch.max-md:hidden
              = f.hidden_field :filter, value: params[:filter], data: {"deals-target": "filterValue"}
              - if current_user.lender?
                - SelectOptions::FILTER_DEALS_LENDER.each do |filter|
                  %a{href: dashboard_index_path(request.query_parameters), class: "text-center font-medium w-24 py-1 px-3 border border-gray-200 first:rounded-l last:rounded-r #{(params[:filter].eql? filter[1]) || (filter[1] === 'all' && !params[:filter].present?) ? 'bg-blue-600 border border-blue-600 text-white pointer-events-none' : 'bg-white'}", data: {action: "click->deals#submitStatusFilter", "filter-value": filter[1]}}= filter[0]
              - unless current_user.lender?
                - SelectOptions::FILTER_DEALS.each do |filter|
                  %a{href: dashboard_index_path(request.query_parameters), class: "text-center font-medium w-24 py-1 px-3 border border-gray-200 first:rounded-l last:rounded-r #{(params[:filter].eql? filter[1]) || (filter[1] === 'all' && !params[:filter].present?) ? 'bg-blue-600 border border-blue-600 text-white pointer-events-none' : 'bg-white'}", data: {action: "click->deals#submitStatusFilter", "filter-value": filter[1]}}= filter[0]
          = form_with url: dashboard_index_path(request.query_parameters), method: :get, class: "md:hidden", data: {"deals-target": "statusFilterFormMobile"} do |f|
            .flex.items-start.self-stretch.bg-white.md:hidden
              - if current_user.lender?
                = f.select :filter, options_for_select(SelectOptions::FILTER_DEALS_LENDER, params[:filter]), {}, {:class => "px-3 py-1 pr-10 rounded-l border-gray-200 font-medium hover:cursor-pointer md:hidden", :onchange => "this.form.submit()"}
              - unless current_user.lender?
                = f.select :filter, options_for_select(SelectOptions::FILTER_DEALS, params[:filter]), {}, {:class => "px-3 py-1 pr-10 rounded-l border-gray-200 font-medium hover:cursor-pointer md:hidden", :onchange => "this.form.submit()"}
          .flex.items-center.lg:divide-x.divide-gray-200
            .flex.gap-2.pr-2.max-lg:hidden
              .flex.flex-col.p-2.content-center.justify-center.rounded-md{"data-action" => "click->deals#switchView", "data-deals-target" => "cardViewMenu", class: "#{(@deals_view.present? && @deals_view.eql?('card')) ? 'bg-gray-200 hover:cursor-auto' : 'bg-white hover:cursor-pointer'}"}
